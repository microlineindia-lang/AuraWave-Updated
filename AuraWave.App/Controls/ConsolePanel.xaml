<UserControl x:Class="AuraWave.App.Controls.ConsolePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AuraWave.App.Controls"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="#020617"
        BorderBrush="{StaticResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="10"
        Padding="10">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock Text="{Binding Title, ElementName=Root}"
                       FontWeight="SemiBold"/>

                <TextBlock Text="{Binding RightText, ElementName=Root}"
                       DockPanel.Dock="Right"
                       Style="{StaticResource MutedTextStyle}"
                       VerticalAlignment="Center"/>
            </DockPanel>

            <TextBox Grid.Row="1"
                 Text="{Binding LogText, ElementName=Root}"
                 Background="#020617"
                 Foreground="{StaticResource Brush.TextSecondary}"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="13"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        </Grid>

    </Border>

</UserControl>

