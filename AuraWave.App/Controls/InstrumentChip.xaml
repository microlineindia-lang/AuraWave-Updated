<UserControl x:Class="AuraWave.App.Controls.InstrumentChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="56"
             d:DesignWidth="160">

    <Border Background="{StaticResource Brush.CardBackgroundAlt}"
            BorderBrush="{StaticResource Brush.BorderSubtle}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12,10"
            Margin="4"
            MinWidth="140">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Ellipse Grid.Column="0"
                     Width="8" Height="8"
                     Fill="{Binding StatusBrush, ElementName=Root}"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding DeviceName, ElementName=Root}"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Detail, ElementName=Root}"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Text="{Binding Status, ElementName=Root}"
                       Foreground="{Binding StatusBrush, ElementName=Root}"
                       FontSize="11.5"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </Grid>
    </Border>

</UserControl>
