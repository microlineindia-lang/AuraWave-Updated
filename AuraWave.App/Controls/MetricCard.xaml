<UserControl x:Class="AuraWave.App.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AuraWave.App.Controls"
             mc:Ignorable="d" 
             x:Name="Root"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="{StaticResource Brush.CardBackground}"
        BorderBrush="{StaticResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="12"
        Padding="14"
        Margin="6">

        <StackPanel>

            <TextBlock Text="{Binding Title, ElementName=Root}"
                   Style="{StaticResource MutedTextStyle}"/>

            <StackPanel Orientation="Horizontal"
                    Margin="0,6,0,0">

                <TextBlock Text="{Binding Value, ElementName=Root}"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="{Binding Unit, ElementName=Root}"
                       FontSize="16"
                       Foreground="{StaticResource Brush.TextMuted}"
                       Margin="6,8,0,0"/>

            </StackPanel>

            <TextBlock Text="{Binding Caption, ElementName=Root}"
                   Style="{StaticResource MutedTextStyle}"
                   Margin="0,4,0,0"/>

        </StackPanel>

    </Border>

</UserControl>

