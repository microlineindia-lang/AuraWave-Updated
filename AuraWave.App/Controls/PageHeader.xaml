<UserControl x:Class="AuraWave.App.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="72"
             d:DesignWidth="800">

    <DockPanel LastChildFill="False" Margin="0,0,0,4">

        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
            <TextBlock Text="{Binding Title, ElementName=Root}"
                       Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                       Style="{StaticResource MutedTextStyle}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       MaxWidth="720"/>
        </StackPanel>

        <ContentPresenter x:Name="ActionsHost"
                          DockPanel.Dock="Right"
                          Content="{Binding ActionContent, ElementName=Root}"
                          VerticalAlignment="Center"/>

    </DockPanel>

</UserControl>
