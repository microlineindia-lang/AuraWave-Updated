<UserControl x:Class="AuraWave.App.Controls.PlotSurface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Style="{StaticResource SectionTitleStyle}"/>
                <Border Background="#12243D"
                        BorderBrush="#234060"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,3"
                        Margin="12,2,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding PlotKind, ElementName=Root}"
                               Style="{StaticResource BadgeTextStyle}"/>
                </Border>
            </StackPanel>
            <TextBlock Text="{Binding Hint, ElementName=Root}"
                       DockPanel.Dock="Right"
                       Style="{StaticResource MutedTextStyle}"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.PlotBackground}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True">

            <Grid>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="1" Grid.ColumnSpan="4" BorderBrush="{StaticResource Brush.PlotGrid}" BorderThickness="0,1,0,0"/>
                    <Border Grid.Row="2" Grid.ColumnSpan="4" BorderBrush="{StaticResource Brush.PlotGrid}" BorderThickness="0,1,0,0"/>
                    <Border Grid.Row="3" Grid.ColumnSpan="4" BorderBrush="{StaticResource Brush.PlotGrid}" BorderThickness="0,1,0,0"/>
                    <Border Grid.Column="1" Grid.RowSpan="4" BorderBrush="{StaticResource Brush.PlotGrid}" BorderThickness="1,0,0,0"/>
                    <Border Grid.Column="2" Grid.RowSpan="4" BorderBrush="{StaticResource Brush.PlotGrid}" BorderThickness="1,0,0,0"/>
                    <Border Grid.Column="3" Grid.RowSpan="4" BorderBrush="{StaticResource Brush.PlotGrid}" BorderThickness="1,0,0,0"/>
                </Grid>

                <Viewbox Stretch="Uniform" MaxWidth="260" MaxHeight="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="260" Height="260">
                        <Ellipse Width="260" Height="260" Stroke="{StaticResource Brush.PlotAxis}" StrokeThickness="1" Opacity="0.55"/>
                        <Ellipse Width="180" Height="180" Stroke="{StaticResource Brush.PlotGrid}" StrokeThickness="1"/>
                        <Ellipse Width="100" Height="100" Stroke="{StaticResource Brush.PlotGrid}" StrokeThickness="1"/>
                        <Line X1="130" Y1="130" X2="130" Y2="16" Stroke="{StaticResource Brush.Cyan}" StrokeThickness="2" Opacity="0.85"/>
                    </Grid>
                </Viewbox>

                <TextBlock Text="{Binding Placeholder, ElementName=Root}"
                           Foreground="{StaticResource Brush.TextDisabled}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,12"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>
