<UserControl x:Class="AuraWave.App.Controls.SectionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Style="{StaticResource SectionTitleStyle}"/>
                <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <ContentPresenter Grid.Row="1" Content="{Binding Body, ElementName=Root}"/>
        </Grid>
    </Border>

</UserControl>
