<UserControl x:Class="AuraWave.App.Controls.StatusTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AuraWave.App.Controls"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Border Background="{StaticResource Brush.CardBackground}"
        BorderBrush="{StaticResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="12"
        Padding="12"
        Margin="4">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding Title, ElementName=Root}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                       Style="{StaticResource MutedTextStyle}"
                       Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Status pill on right -->
            <Border Grid.Column="1"
                Background="{Binding StatusBrush, ElementName=Root}"
                CornerRadius="100"
                VerticalAlignment="Center"
                Padding="10,4"
                Margin="8,0,0,0">

                <TextBlock Text="{Binding Status, ElementName=Root}"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="SemiBold"/>

            </Border>

        </Grid>

    </Border>

</UserControl>
