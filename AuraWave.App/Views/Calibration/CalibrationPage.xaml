<Page x:Class="AuraWave.App.Views.Calibration.CalibrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:AuraWave.App.Controls"
      mc:Ignorable="d"
      Title="Calibration"
      Background="{StaticResource Brush.AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,16,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:PageHeader Title="Calibration"
                                 Subtitle="VNA calibration kit, cable compensation, reference antenna, and turntable zero"/>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="260"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Calibration Workflow" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="SOLT / TRL sequence" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,14"/>
                        <CheckBox Content="1. Connect calibration kit"/>
                        <CheckBox Content="2. Open standard"/>
                        <CheckBox Content="3. Short standard"/>
                        <CheckBox Content="4. Load standard"/>
                        <CheckBox Content="5. Through standard"/>
                        <CheckBox Content="6. Save calibration profile"/>
                        <Separator/>
                        <Button Content="Start VNA Calibration" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,8"
                                Command="{Binding StartVnaCalibrationCommand}"/>
                        <Button Content="Load Profile" Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <TextBlock Text="Calibration Status" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,14"/>
                        <UniformGrid Rows="1" Columns="3">
                            <Border Style="{StaticResource InsetPanelStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="VNA Calibration" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding VnaCalStatus}" Foreground="{StaticResource Brush.Orange}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InsetPanelStyle}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="Position Zero" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding PositionZero}" Foreground="{StaticResource Brush.Red}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InsetPanelStyle}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Reference Antenna" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding ReferenceAntenna}" Foreground="{StaticResource Brush.TextMuted}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Position Calibration" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Mechanical zero vs electrical reference" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,14"/>
                        <Button Content="Home Turntable" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8"
                                Command="{Binding HomeTurntableCommand}"/>
                        <Button Content="Set Current as 0°" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8"/>
                        <Button Content="Verify 90° / 180° / 360°" Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <controls:ConsolePanel Title="Calibration Log" LogText="{Binding CalibrationLog}"/>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
