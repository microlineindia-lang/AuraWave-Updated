<Page x:Class="AuraWave.App.Views.Dashboard.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:AuraWave.App.Controls"
      mc:Ignorable="d"
      Title="Dashboard"
      Background="{StaticResource Brush.AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,16,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <controls:PageHeader Title="Dashboard"
                                 Subtitle="System overview, instrument health, and quick measurement launch">
                <controls:PageHeader.ActionContent>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Start Scan" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"
                                Command="{Binding StartScanCommand}"/>
                        <Button Content="Home Turntable" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding HomeTurntableCommand}"/>
                    </StackPanel>
                </controls:PageHeader.ActionContent>
            </controls:PageHeader>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.RowSpan="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Hardware Status" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Live connection state" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,16"/>
                        <controls:StatusTile Title="VNA" Subtitle="Anritsu MS4644B" Status="Disconnected" StatusBrush="{StaticResource Brush.Red}"/>
                        <controls:StatusTile Title="Turntable" Subtitle="Azimuth positioner" Status="Ready" StatusBrush="{StaticResource Brush.Green}"/>
                        <controls:StatusTile Title="Motor Driver" Subtitle="Stepper / simulator" Status="Active" StatusBrush="{StaticResource Brush.Cyan}"/>
                        <controls:StatusTile Title="RF Switch" Subtitle="Polarization" Status="E-Plane" StatusBrush="{StaticResource Brush.Blue}"/>
                        <controls:StatusTile Title="Chamber" Subtitle="Anechoic-01" Status="Safe" StatusBrush="{StaticResource Brush.Green}"/>
                        <Separator/>
                        <Button Content="Switch E-Plane" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8"
                                Command="{Binding SwitchEPlaneCommand}"/>
                        <Button Content="Switch H-Plane" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8"
                                Command="{Binding SwitchHPlaneCommand}"/>
                        <Button Content="EMERGENCY STOP" Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding EmergencyStopCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <controls:PlotSurface Title="Live Polar Plot" PlotKind="POLAR"
                                          Placeholder="ScottPlot — radiation pattern (stage 2)"
                                          Hint="θ = 0° → 360°"/>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <controls:PlotSurface Title="S-Parameters" PlotKind="S11 / S21"
                                          Placeholder="Magnitude &amp; phase vs frequency"
                                          Hint="GHz"/>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <controls:PlotSurface Title="Chamber Layout" PlotKind="3D PREVIEW"
                                          Placeholder="AUT, reference antenna, turntable"
                                          Hint="HelixToolkit (stage 2)"/>
                </Border>

                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Scan Progress" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="No active measurement sequence" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,20"/>
                        <ProgressBar Value="{Binding ScanProgress}" Maximum="100"/>
                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <controls:MetricCard Title="Current Angle" Value="{Binding CurrentAngle}" Caption="Azimuth"/>
                            <controls:MetricCard Grid.Column="1" Title="Frequency" Value="{Binding Frequency}" Caption="RF point"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,6,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent Projects / Measurement Queue" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Project" Width="*" Binding="{Binding Project}"/>
                            <DataGridTextColumn Header="Type" Width="160" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="Frequency" Width="140" Binding="{Binding Frequency}"/>
                            <DataGridTextColumn Header="Status" Width="120" Binding="{Binding Status}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
