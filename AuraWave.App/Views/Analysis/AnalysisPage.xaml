<Page x:Class="AuraWave.App.Views.Analysis.AnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:AuraWave.App.Controls"
      xmlns:plot="clr-namespace:AuraWave.Plotting;assembly=AuraWave.Plotting"
      mc:Ignorable="d"
      Title="Analysis"
      Background="{StaticResource Brush.AppBackground}">

    <Grid Margin="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:PageHeader Title="Analysis"
                             Subtitle="Anritsu VNA S-parameters (S11–S22), radiation pattern polar plot, and antenna metrics"/>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Measurement Library" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="VNA sweeps and turntable pattern scans" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,14"/>
                    <TextBlock Text="{Binding LibraryStatus}" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <Button Content="Import Anritsu VNA CSV" Style="{StaticResource PrimaryButtonStyle}" Margin="0,8,0,0"
                            Command="{Binding ImportVnaCsvCommand}"/>
                    <Button Content="Import Pattern / Touchstone" Style="{StaticResource SecondaryButtonStyle}" Margin="0,8,0,0"
                            Command="{Binding ImportDataCommand}"/>

                    <TextBlock Text="VNA trace" Style="{StaticResource MutedTextStyle}" Margin="0,16,0,4"
                               Visibility="{Binding HasVnaData, Converter={StaticResource BoolToVisibility}}"/>
                    <ComboBox ItemsSource="{Binding TraceChoices}" SelectedItem="{Binding SelectedTrace}"
                              Visibility="{Binding HasVnaData, Converter={StaticResource BoolToVisibility}}"/>
                    <CheckBox Content="Overlay S11–S22" IsChecked="{Binding OverlayAllTraces}" Margin="0,8,0,0"
                              Visibility="{Binding HasVnaData, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="{Binding InstrumentSummary}" Style="{StaticResource MutedTextStyle}" Margin="0,14,0,4" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding VnaSummary}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap"
                               Visibility="{Binding HasVnaData, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Column="1" Background="Transparent" BorderThickness="0">
                <TabItem Header="S-Parameters (VNA)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,8">
                            <plot:SParameterPlotControl x:Name="VnaPlot"/>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="20,14"
                                Visibility="{Binding HasVnaData, Converter={StaticResource BoolToVisibility}}">
                            <UniformGrid Columns="3">
                                <controls:MetricCard Title="S11 minimum" Value="{Binding S11Min}" Caption="Return loss"/>
                                <controls:MetricCard Title="S21 @ 2.4 GHz" Value="{Binding S21At24Ghz}" Caption="Nearest bin"/>
                                <controls:MetricCard Title="Traces" Value="S11–S22" Caption="LOGMAG sweep"/>
                            </UniformGrid>
                        </Border>
                        <TextBlock Grid.Row="0" Text="Import your Anritsu MS46122B CSV (e.g. UEM Ayan S parameters) to view S11, S12, S21, and S22 vs frequency."
                                   Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding ShowVnaEmptyHint, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Radiation Pattern">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,8">
                            <plot:PolarPlotControl x:Name="AnalysisPolarPlot"/>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="20,14">
                            <UniformGrid Columns="4">
                                <controls:MetricCard Title="Peak Gain" Value="{Binding PeakGain}" Caption="Main lobe"/>
                                <controls:MetricCard Title="HPBW" Value="{Binding Hpbw}" Caption="Half-power"/>
                                <controls:MetricCard Title="F/B Ratio" Value="{Binding FrontToBack}" Caption="Front-to-back"/>
                                <controls:MetricCard Title="Side Lobe" Value="{Binding SideLobe}" Caption="First sidelobe"/>
                            </UniformGrid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Page>
