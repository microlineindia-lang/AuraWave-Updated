<Page x:Class="AuraWave.App.Views.Measurement.LiveMeasurementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:AuraWave.App.Controls"
      xmlns:plot="clr-namespace:AuraWave.Plotting;assembly=AuraWave.Plotting"
      mc:Ignorable="d"
      Title="Live Measurement"
      Background="{StaticResource Brush.AppBackground}">

    <Grid Margin="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <controls:PageHeader Title="Live Measurement"
                             Subtitle="Real-time scan — polar pattern, S21 vs angle, 3D mesh, acquisition table">
            <controls:PageHeader.ActionContent>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Pause" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                            Command="{Binding PauseCommand}"/>
                    <Button Content="Resume" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"
                            Command="{Binding ResumeCommand}"/>
                    <Button Content="Abort" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,0"
                            Command="{Binding AbortCommand}"/>
                    <Button Content="E-STOP" Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding EmergencyStopCommand}"/>
                </StackPanel>
            </controls:PageHeader.ActionContent>
        </controls:PageHeader>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <plot:PolarPlotControl x:Name="PolarPlot"/>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <plot:SParameterPlotControl x:Name="S21Plot"/>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <plot:RadiationMesh3DControl x:Name="Mesh3D"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Acquisition Data" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding DataRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Angle (°)" Binding="{Binding Angle}" Width="90"/>
                            <DataGridTextColumn Header="S21 (dB)" Binding="{Binding S21}" Width="100"/>
                            <DataGridTextColumn Header="Gain" Binding="{Binding Gain}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="5" Margin="0,8,0,0">
            <controls:MetricCard Title="Current Angle" Value="{Binding CurrentAngle}" Unit="°" Caption="Azimuth"/>
            <controls:MetricCard Title="Frequency" Value="{Binding Frequency}" Unit="GHz" Caption="RF point"/>
            <controls:MetricCard Title="Live S21" Value="{Binding LiveS21}" Unit="dB" Caption="Link magnitude"/>
            <controls:MetricCard Title="Progress" Value="{Binding Progress}" Unit="%" Caption="Scan completion"/>
            <controls:MetricCard Title="ETA" Value="{Binding Eta}" Caption="Remaining time"/>
        </UniformGrid>
    </Grid>
</Page>
