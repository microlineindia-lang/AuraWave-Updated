<Window x:Class="AuraWave.App.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:AuraWave.App.Controls"
        xmlns:nav="clr-namespace:AuraWave.App.Navigation"
        mc:Ignorable="d"
        Title="AuraWave — Antenna Radiation Measurement"
        Height="920"
        Width="1560"
        MinHeight="720"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="ConsoleRow" Height="168"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="{StaticResource Brush.TopbarBackground}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="9"
                            Background="{StaticResource Brush.AccentMuted}"
                            BorderBrush="#2A5088" BorderThickness="1">
                        <TextBlock Text="AW" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Accent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="AuraWave" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="RF / Microwave Antenna Measurement"
                                   Foreground="{StaticResource Brush.TextMuted}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Project:" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" FontSize="12"/>
                        <Border Background="#12243D" CornerRadius="4" Padding="8,2" Margin="16,0,0,0">
                            <TextBlock Text="{Binding RunModeBadge}" Foreground="{StaticResource Brush.Cyan}" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource Brush.TextMuted}">
                        <Run Text="Scan:"/><Run Text=" "/><Run Text="{Binding ScanState}" Foreground="{StaticResource Brush.Green}"/>
                        <Run Text="  |  "/><Run Text="Operator:"/><Run Text=" "/><Run Text="{Binding OperatorName}"/>
                        <Run Text="  |  "/><Run Text="Chamber:"/><Run Text=" "/><Run Text="{Binding ChamberId}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                            ToolTip="New measurement project">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{x:Static nav:NavGlyphs.Project}" FontFamily="{StaticResource Font.Icons}" Margin="0,0,8,0"/>
                            <TextBlock Text="New Project"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Notifications">
                        <TextBlock Text="{x:Static nav:NavGlyphs.Notification}" FontFamily="{StaticResource Font.Icons}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource Brush.SidebarBackground}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="WORKSPACE" Style="{StaticResource SidebarSectionLabelStyle}"/>

                        <Button x:Name="NavDashboard" Tag="Active" Style="{StaticResource NavButtonStyle}" Click="NavDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Dashboard}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavHardware" Style="{StaticResource NavButtonStyle}" Click="NavHardware_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Hardware}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Hardware Control" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSetup" Style="{StaticResource NavButtonStyle}" Click="NavSetup_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Setup}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Measurement Setup" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavLive" Style="{StaticResource NavButtonStyle}" Click="NavLive_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Live}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Live Measurement" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="ANALYSIS" Style="{StaticResource SidebarSectionLabelStyle}"/>

                        <Button x:Name="NavAnalysis" Style="{StaticResource NavButtonStyle}" Click="NavAnalysis_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Analysis}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Analysis" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavCalibration" Style="{StaticResource NavButtonStyle}" Click="NavCalibration_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Calibration}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Calibration" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavReports" Style="{StaticResource NavButtonStyle}" Click="NavReports_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Reports}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Reports" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="SYSTEM" Style="{StaticResource SidebarSectionLabelStyle}"/>

                        <Button x:Name="NavSettings" Style="{StaticResource NavButtonStyle}" Click="NavSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Settings}" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" Margin="12" Style="{StaticResource InsetPanelStyle}" Padding="14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{x:Static nav:NavGlyphs.Safety}" FontFamily="{StaticResource Font.Icons}"
                                           Foreground="{StaticResource Brush.Green}" Margin="0,0,8,0"/>
                                <TextBlock Text="System Safety" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SafetyInterlockText}" Foreground="{StaticResource Brush.Green}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding EstopCircuitText}" Foreground="{StaticResource Brush.TextMuted}" FontSize="11" Margin="0,0,0,12"/>
                            <Button Content="EMERGENCY STOP" Style="{StaticResource DangerButtonStyle}" Height="40" Margin="0,0,0,8"
                                    Command="{Binding EmergencyStopCommand}"/>
                            <Button Content="Clear E-STOP" Style="{StaticResource SecondaryButtonStyle}" Height="32"
                                    Command="{Binding ClearEmergencyStopCommand}"
                                    Visibility="{Binding IsEstopActive, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Main content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Instrument strip -->
                <Border Grid.Row="0"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <UniformGrid Columns="5">
                        <controls:InstrumentChip DeviceName="VNA"
                                                 Detail="{Binding VnaDetail}"
                                                 Status="{Binding VnaStatus}"
                                                 StatusBrush="{Binding VnaStatusBrush}"/>
                        <controls:InstrumentChip DeviceName="Turntable"
                                                 Detail="{Binding TurntableDetail}"
                                                 Status="{Binding TurntableStatus}"
                                                 StatusBrush="{Binding TurntableStatusBrush}"/>
                        <controls:InstrumentChip DeviceName="Motor Driver"
                                                 Detail="{Binding MotorDetail}"
                                                 Status="{Binding MotorStatus}"
                                                 StatusBrush="{Binding MotorStatusBrush}"/>
                        <controls:InstrumentChip DeviceName="RF Switch"
                                                 Detail="{Binding RfSwitchDetail}"
                                                 Status="{Binding RfSwitchStatus}"
                                                 StatusBrush="{Binding RfSwitchStatusBrush}"/>
                        <controls:InstrumentChip DeviceName="Chamber"
                                                 Detail="{Binding ChamberDetail}"
                                                 Status="{Binding ChamberStatus}"
                                                 StatusBrush="{Binding ChamberStatusBrush}"/>
                    </UniformGrid>
                </Border>

                <Frame x:Name="MainFrame"
                       Grid.Row="1"
                       NavigationUIVisibility="Hidden"
                       Background="{StaticResource Brush.AppBackground}"/>
            </Grid>
        </Grid>

        <!-- Console -->
        <!-- PROFESSIONAL ENTERPRISE CONSOLE -->
<Border Grid.Row="2"
        x:Name="ConsolePanel"
        Background="#070D17"
        BorderBrush="{StaticResource Brush.Border}"
        BorderThickness="0,1,0,0">

    <Grid>

        <!-- subtle top glow -->
        <Border Height="1"
                VerticalAlignment="Top"
                Background="#1E3A5F"
                Opacity="0.7"/>

        <Grid Margin="18,12">

            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#0B1320"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="10">

                <Grid Margin="14,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- console indicator -->
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{StaticResource Brush.Green}"
                                 VerticalAlignment="Center"/>

                        <TextBlock Text="{x:Static nav:NavGlyphs.Console}"
                                   FontFamily="{StaticResource Font.Icons}"
                                   Foreground="{StaticResource Brush.Cyan}"
                                   FontSize="14"
                                   Margin="12,0,10,0"
                                   VerticalAlignment="Center"/>

                        <StackPanel>

                            <TextBlock Text="System Console"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{StaticResource Brush.TextPrimary}"/>

                            <TextBlock Text="SCPI Communication · Instrument Logs · Diagnostics"
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.TextMuted}"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- tags -->
                        <Border Background="#10233D"
                                CornerRadius="5"
                                Padding="10,4"
                                Margin="0,0,8,0">
                            <TextBlock Text="SCPI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Blue}"/>
                        </Border>

                        <Border Background="#142819"
                                CornerRadius="5"
                                Padding="10,4"
                                Margin="0,0,8,0">
                            <TextBlock Text="SERIAL"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Green}"/>
                        </Border>

                        <Border Background="#2A1C10"
                                CornerRadius="5"
                                Padding="10,4"
                                Margin="0,0,16,0">
                            <TextBlock Text="RF"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Orange}"/>
                        </Border>

                        <!-- status -->
                        <Border Background="#112015"
                                BorderBrush="#1B5E20"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,5"
                                Margin="0,0,12,0">

                            <StackPanel Orientation="Horizontal">

                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="{StaticResource Brush.Green}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>

                                <TextBlock Text="SYSTEM READY"
                                           Foreground="{StaticResource Brush.Green}"
                                           FontSize="11"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Clear"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="30"
                                MinWidth="56"
                                Padding="12,0"
                                Margin="0,0,6,0"
                                ToolTip="Clear console log"
                                Click="ClearConsole_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONSOLE OUTPUT -->
            <Border Grid.Row="2"
                    Background="#02060D"
                    BorderBrush="#1A2435"
                    BorderThickness="1"
                    CornerRadius="10">

                <Grid>

                    <!-- inner subtle glow -->
                    <Border Margin="1"
                            CornerRadius="9"
                            BorderBrush="#0F1C2E"
                            BorderThickness="1"/>

                            <TextBox x:Name="ConsoleOutput"
         Margin="0"
         Padding="18"
         Text="{Binding ConsoleText, Mode=OneWay}"
         Background="Transparent"
         Foreground="#C7D2E0"
         BorderThickness="0"
         FontFamily="{StaticResource Font.Mono}"
         FontSize="12.5"
         FontWeight="Medium"
         CaretBrush="{StaticResource Brush.Accent}"

         IsReadOnly="True"
         AcceptsReturn="True"
         AcceptsTab="True"

         TextWrapping="NoWrap"

         VerticalScrollBarVisibility="Auto"
         HorizontalScrollBarVisibility="Auto"

         VerticalContentAlignment="Top"
         HorizontalContentAlignment="Left"

         SelectionBrush="{StaticResource Brush.AccentMuted}"
         SelectionOpacity="0.35"

         SpellCheck.IsEnabled="False" TextChanged="ConsoleOutput_TextChanged"/>

                            <!-- top overlay gradient effect -->
                    <Border Height="40"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="0,1">
                                <GradientStop Color="#10FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</Border>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="#030712"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="14,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ToggleConsoleButton"
                            Content="{Binding ConsoleToggleLabel}"
                            Style="{StaticResource GhostButtonStyle}"
                            Height="26"
                            MinWidth="110"
                            Margin="0,0,16,0"
                            ToolTip="Show or hide system console (Ctrl+`)"
                            Click="ToggleConsole_Click"/>
                    <Ellipse Width="7" Height="7" Fill="{StaticResource Brush.Green}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="FooterStatusText" Text="{Binding FooterStatus}" Foreground="{StaticResource Brush.Green}" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Brush.TextDisabled}" FontSize="11">
                    AuraWave v1.0 · Physical hardware · Far-field pattern measurement
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
