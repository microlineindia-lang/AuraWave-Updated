<Window x:Class="AuraWave.App.Views.Dialogs.RestartNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AuraWave"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="480"
        Height="220">

    <Border Background="#0F172A"
            BorderBrush="#334155"
            BorderThickness="1"
            CornerRadius="12"
            Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="8" Background="#1E3A5F">
                    <TextBlock Text="↻" FontSize="22" Foreground="#06B6D4"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="AuraWave" FontSize="18" FontWeight="SemiBold"
                           Foreground="#F1F5F9" Margin="14,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16,0,16">
                <TextBlock x:Name="TitleText"
                           Text="AuraWave will restart soon"
                           FontSize="16" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                <TextBlock x:Name="ReasonText"
                           Text="Your settings have been saved."
                           Foreground="#94A3B8" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="CountdownText"
                           Text="Restarting in 5 seconds…"
                           Foreground="#06B6D4" FontSize="14" FontWeight="SemiBold"
                           Margin="0,14,0,0"/>
            </StackPanel>

            <ProgressBar Grid.Row="2" x:Name="ProgressBar"
                         Height="4" Minimum="0" Maximum="100"
                         Foreground="#06B6D4" Background="#1E293B"
                         BorderThickness="0"/>
        </Grid>
    </Border>
</Window>
